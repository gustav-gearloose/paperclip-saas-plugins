# Template for a new customer instance
# Copy this file to customers/<customer-slug>.env and fill in the values.
# Keep PC_PASSWORD out of git — use a .secrets file or pass via env.
PC_HOST=http://localhost:3100
# PC_ORIGIN: public HTTPS URL Paperclip is served at via Caddy.
# Required when Paperclip sits behind HTTPS — its CSRF check validates the Origin
# header against PAPERCLIP_PUBLIC_URL. The MCP proxy connects via localhost but must
# send the public URL as Origin. Omit (or set to http://localhost:3100) for NUC/LAN installs.
PC_ORIGIN=https://<domain>
PC_EMAIL=admin@customer.example
# PC_PASSWORD=
PC_COMPANY_ID=<uuid-from-paperclip-settings>
SSH_HOST=<ssh-alias-for-their-server>
CONTAINER=paperclipai-docker-server-1
